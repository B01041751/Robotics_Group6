<launch>
    <env name="GAZEBO_RESOURCE_PATH"
         value="$(find com760cw2_group6)/media/materials/scripts:$(find com760cw2_group6)/media/materials/textures:$(optenv GAZEBO_RESOURCE_PATH)"/>

    <arg name="bot0_x"   default="$(env BOT0_X)"/>
    <arg name="bot0_y"   default="$(env BOT0_Y)"/>
    <arg name="bot0_z"   default="$(env BOT0_Z)"/>
    <arg name="bot0_yaw" default="$(env BOT0_YAW)"/>
    <arg name="bot1_x"   default="$(env BOT1_X)"/>
    <arg name="bot1_y"   default="$(env BOT1_Y)"/>
    <arg name="bot1_z"   default="$(env BOT1_Z)"/>
    <arg name="bot1_yaw" default="$(env BOT1_YAW)"/>
    <arg name="gas1_x"   default="$(env GAS1_X)"/>
    <arg name="gas1_y"   default="$(env GAS1_Y)"/>

    <include file="$(find gazebo_ros)/launch/empty_world.launch">
        <arg name="world_name" value="$(find com760cw2_group6)/worlds/environment_foot.world"/>
        <arg name="paused"     value="false"/>
        <arg name="use_sim_time" value="true"/>
        <arg name="gui"        value="true"/>
    </include>

    <!-- Bot 0 -->
    <param name="Group6Bot_0/robot_description"
           command="$(find xacro)/xacro '$(find com760cw2_group6)/urdf/Group6Bot_0.urdf.xacro'" />

    <node pkg="gazebo_ros" type="spawn_model" name="spawn_urdf_0"
          args="-urdf -model Group6Bot_0
                -x $(arg bot0_x) -y $(arg bot0_y) -z $(arg bot0_z) -Y $(arg bot0_yaw)
                -param Group6Bot_0/robot_description" />

    <node pkg="robot_state_publisher" type="robot_state_publisher" name="rsp_0">
        <remap from="robot_description" to="Group6Bot_0/robot_description" />
        <remap from="joint_states"      to="Group6Bot_0/joint_states" />
    </node>
    <node pkg="joint_state_publisher" type="joint_state_publisher" name="jsp_0">
        <remap from="robot_description" to="Group6Bot_0/robot_description"/>
        <remap from="joint_states"      to="Group6Bot_0/joint_states"/>
    </node>

    <!--
    <param name="Group6Bot_1/robot_description"
           command="$(find xacro)/xacro '$(find com760cw2_group6)/urdf/Group6Bot_1.urdf.xacro'" />

    <node pkg="gazebo_ros" type="spawn_model" name="spawn_urdf_1"
          args="-urdf -model Group6Bot_1
                -x $(arg bot1_x) -y $(arg bot1_y) -z $(arg bot1_z) -Y $(arg bot1_yaw)
                -param Group6Bot_1/robot_description"/>

    <node pkg="robot_state_publisher" type="robot_state_publisher" name="rsp_1">
        <remap from="robot_description" to="Group6Bot_1/robot_description" />
        <remap from="joint_states"      to="Group6Bot_1/joint_states" />
    </node>
    <node pkg="joint_state_publisher" type="joint_state_publisher" name="jsp_1">
        <remap from="robot_description" to="Group6Bot_1/robot_description"/>
        <remap from="joint_states"      to="Group6Bot_1/joint_states"/>
    </node>

    <node pkg="com760cw2_group6" type="Group6_Bot_Bug2_Algorithm.py" name="bot1_bug2"
          ns="Group6Bot_1" output="screen">
        <param name="auto_start" value="true"/>
        <param name="goal_x"     value="$(arg gas_x)"/>
        <param name="goal_y"     value="$(arg gas_y)"/>
    </node>

    <node pkg="com760cw2_group6" type="Group6Bot_1_camera_view.py" name="Bot1_Camera"
          ns="Group6Bot_1" output="screen" />

    <node pkg="gmapping" type="slam_gmapping" name="bot1_gmapping" ns="Group6Bot_1" output="screen">
        <remap from="scan" to="/Group6Bot_1/scan"/>
        <remap from="map"  to="/map"/>
        <param name="base_frame"          value="Group6Bot_1/base_link"/>
        <param name="odom_frame"          value="Group6Bot_1/odom"/>
        <param name="map_frame"           value="map"/>
        <param name="map_update_interval" value="2.0"/>
        <param name="maxUrange"           value="9.0"/>
        <param name="delta"               value="0.05"/>
        <param name="particles"           value="30"/>
        <param name="xmin"                value="-25.0"/>
        <param name="xmax"                value="25.0"/>
        <param name="ymin"                value="-25.0"/>
        <param name="ymax"                value="25.0"/>
    </node>
    -->

    <!-- Camera view for Bot 0 only -->
    <node pkg="com760cw2_group6" type="Group6Bot_1_camera_view.py" name="Bot0_Camera"
          ns="Group6Bot_0" output="screen" />

    <!-- RViz map visualisation -->
    <node pkg="rviz" type="rviz" name="rviz"
          args="-d $(find com760cw2_group6)/mappingpath.rviz" output="screen"/>

</launch>
