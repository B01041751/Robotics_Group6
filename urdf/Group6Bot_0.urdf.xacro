<?xml version="1.0" ?>
<!-- URDF with Xacro: Defining the robot called "com760Bot" specifying the parametric macros for inertia as well as the 
     basic geometry the box, wheels and caster as well as the Gazebo plugins the lidar, camera, bumper and diff drive. 
     Note: File uses xacro properties and macros to reduce the repetition, as well as make the mass/inertia consistent.
     The "prefix" is used in regards namespace for the links/joints so multiple robots can spawn without the TF/name clashes. -->
<robot name="com760Bot" xmlns:xacro="https://www.ros.org/wiki/xacro" >

  <!-- The prefix/namespace, this is where everything becomes Group6Bot_0/</link>. This is important in the multiple robot 
       Simulation, TF and the topic names especially when the plugins use the robotNamespace. -->
  <xacro:property name="prefix" value="Group6Bot_0"/>

  <!-- This is where the resusable materials are used for the RViz and URDF visuals happen.
       These are URDF materials, not the Gazebo materials, they are reused by name in <visual><material name="..."/> -->
       
  <material name="purple"><color rgba="0.5 0 0.5 1"/></material>
  <material name="black"><color rgba="0.0 0.0 0.0 1.0"/></material>
  <material name="red"><color rgba="1.0 0.0 0.0 1.0"/></material>

  <!-- This is where the xacro macro is set for the inertia for the solid cylinder is aligned with its axis. The parameters are:
      m = mass (kg)
      r = radius (m)
      h = length/height (m)
      These produce a complete <inertial> tag. By using the analytic inertia, this helps the Gazebo physics in regards to stability
      verses leaving the inertia blank and being unrealistic. -->
  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <!-- This is for the solid cylinder:
          Ixx = Iyy = (m/12) * (3r^2 + h^2)
          Izz = (m/2) * r^2
          The Off-diagonals are set to 0, this is because we assume the principal axes aligned with the link frame. -->
      <inertia
        ixx="${(m/12)*(3*r*r+h*h)}" ixy="0" ixz="0"
        iyy="${(m/12)*(3*r*r+h*h)}" iyz="0"
        izz="${(m/2)*(r*r)}"/>
    </inertial>
  </xacro:macro>

  <!-- This xacro macro: it is for the inertia of the solid box ensuring it is a rectangular prism. The parameters are set to:
      m = mass (kg)
      w = size in x (m)  [depending on the convention]
      h = size in z (m)
      d = size in y (m)
      Within the URDF, the inertia has been defined around the link frames origin. -->
  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <mass value="${m}"/>
      <!-- This is the solid box being defined:
          Ixx = (m/12) * (h^2 + d^2)
          Iyy = (m/12) * (w^2 + d^2)
          Izz = (m/12) * (w^2 + h^2)
          It assumes the link axes are aligned with the boxes axes. -->
      <inertia
        ixx="${(m/12)*(h*h+d*d)}" ixy="0" ixz="0"
        iyy="${(m/12)*(w*w+d*d)}" iyz="0"
        izz="${(m/12)*(w*w+h*h)}"/>
    </inertial>
  </xacro:macro>

  <!-- This is the base_footprint. It is a conventional ROS frame that is used for 2D naviagation - the Nav Stack and the costmaps.
       It usually has no visuals/collision/inertial also known as the pure frame. It lies on the ground plan as z=0 and yaw only. -->
  <link name="${prefix}/base_footprint"/>

  <!-- This is the fixed joint where it is connecting to the base_foot to the base_link. The origin lifts the base_link up by a 0.16m
       relative to the base_footprint. This design choice ensure the wheels/caster are actually touching the ground given the offset. -->
  <joint name="base_joint" type="fixed">
    <parent link="${prefix}/base_footprint"/>
    <child link="${prefix}/base_link"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/>
  </joint>

  <!-- This is where the base_link is defined: this is the main body or the chassis of the robot. It has a visual as well as a collision for 
       physics as well as the inertial. The visual and collision can be same geometry but sometimes the collision is simplified. -->
  <link name="${prefix}/base_link">
    <visual>
      <geometry><box size="0.4 0.22 0.1"/></geometry>
      <material name="purple"/>
    </visual>

    <!-- This is where the collision geometry is used for the physics and the contacts.
         The name attribute is helpful for debugging purposes. -->
    <collision name="base_collision">
      <geometry><box size="0.4 0.22 0.1"/></geometry>
    </collision>

    <!-- The inertia is approximately 5kg for the chassis, which is matching the dimensions. -->
    <xacro:box_inertia m="5.0" w="0.4" h="0.1" d="0.22"/>
  </link>

  <!-- This is where the bumper_link is being defined. There will be a red bar at the front which is intended for contact sensing. It is also important 
       for collisions, this is because the contact sensor plugin watches for a specific collision element. -->
  <link name="${prefix}/bumper_link">
    <visual>
      <geometry><box size="0.02 0.22 0.05"/></geometry>
      <material name="red"/>
    </visual>
    <collision name="bumper_collision">
      <geometry><box size="0.02 0.22 0.05"/></geometry>
    </collision>
    <xacro:box_inertia m="0.1" w="0.02" h="0.05" d="0.22"/>
  </link>

  <!-- This is for the bumper_joint, it is fixed to the base_link and is positioned slightly forwards as x=0.21. The bumper bar is also at same z origin as 
       the base_link origin as z=0, this is for ensuring it is visually and physically where it is expected to be. -->
  <joint name="${prefix}/bumper_joint" type="fixed">
    <parent link="${prefix}/base_link"/>
    <child link="${prefix}/bumper_link"/>
    <origin xyz="0.21 0 0" rpy="0 0 0"/>
  </joint>

  <!-- This is the left wheel, it is a cylinder wheel. In the URDF, the cylinder axis is set along the z axis on the link frame. The joint rotates the wheel by
       rpy=-1.5708 about x, aliging the cylinder axis with the robots y-axis. It is a common trick used for the joint axis produces a wheel rotation. -->
  <link name="${prefix}/left_wheel">
    <visual>
      <geometry><cylinder length="0.04" radius="0.1"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.04" radius="0.1"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="0.5" r="0.1" h="0.04"/>
  </link>

  <!-- This is where the wheel_left_joint is defined, it is continuous - revolutes without limits, it is for the joint for wheel spinning. It's origin is set to:
        x=-0.1  : The wheel is behind slightly the bodies center.
        y=+0.13 : The left side.
        z=-0.05 : This is under the base_link's origin - this is offset from the base_foot.
      rpy=-1.5708 This rotates the wheel link frame so it aligns the cylinder with the correct axis. 
    - Axis xyz="0 0 1" This means the wheel spins on its local +z axis after the rpy transform.
  -->
  <joint name="${prefix}/wheel_left_joint" type="continuous">
    <parent link="${prefix}/base_link"/>
    <child link="${prefix}/left_wheel"/>
    <origin xyz="-0.1 0.13 -0.05" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- This is the Right wheel being defined with the same structure but it is mirrored in Y axis. -->
  <link name="${prefix}/right_wheel">
    <visual>
      <geometry><cylinder length="0.04" radius="0.1"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.04" radius="0.1"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="0.5" r="0.1" h="0.04"/>
  </link>

  <joint name="${prefix}/wheel_right_joint" type="continuous">
    <parent link="${prefix}/base_link"/>
    <child link="${prefix}/right_wheel"/>
    <origin xyz="-0.1 -0.13 -0.05" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- This is where the caster wheel link is being defined. It is sphere in shape at the rear/front of a y=0 for balance. 
       The friction is controlled via the Gazebo mu1/mu2 later, and are set to 0 so it slides easily. -->
  <link name="${prefix}/caster_link">
    <visual>
      <geometry><sphere radius="0.05"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.05"/></geometry>
    </collision>

    <!-- This is the inertial being manually specified. -->
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="${prefix}/caster_joint" type="fixed">
    <parent link="${prefix}/base_link"/>
    <child link="${prefix}/caster_link"/>
    <!-- This is stating it is positioned forward as x=0.15 and low as z=-0.11. This is due to the base_link being raised by the base_joint,
         this is to ensure the caster still touches the ground plane. -->
    <origin xyz="0.15 0 -0.11" rpy="0 0 0"/>
  </joint>

  <!-- This is where the base_scan is being defined. It is a small cylinder representing the lidar housing. The lidar behaviour is stated in the 
       Gazebo <sensor type="ray">, later in the code. -->
  <link name="${prefix}/base_scan">
    <visual>
      <geometry><cylinder length="0.05" radius="0.05"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.05" radius="0.05"/></geometry>
    </collision>
    <xacro:cylinder_inertia m="0.1" r="0.05" h="0.05"/>
  </link>

  <joint name="${prefix}/scan_joint" type="fixed">
    <parent link="${prefix}/base_link"/>
    <child link="${prefix}/base_scan"/>
    <!-- This is where the lidar is mounted close to the front/top of the base_link. The frame for published LaserScan is later set to the ${prefix}/base_scan. -->
    <origin xyz="0.1 0 0.075" rpy="0 0 0"/>
  </joint>

  <!-- This is where the camera_link is defined, it is a cube for the camera body and the real camera optics are defined in the Gazebo camera sensor. -->
  <link name="${prefix}/camera_link">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
    </collision>
    <xacro:box_inertia m="0.1" w="0.05" h="0.05" d="0.05"/>
  </link>

  <joint name="${prefix}/camera_joint" type="fixed">
    <parent link="${prefix}/base_link"/>
    <child link="${prefix}/camera_link"/>
    <origin xyz="0.2 0 0.075" rpy="0 0 0"/>
  </joint>

  <!-- This area is where the Gazebo's specific extensions are defined. -->
  <!-- The Gazebo camera sensor is attached to the camera_link. The URDF visuals are for RViz purposes, the Gazebo needs sensor blocks under <gazebo reference="...">. -->
  <gazebo reference="${prefix}/camera_link">
    <material>Gazebo/Black</material>

    <sensor type="camera" name="robot_camera">
      <update_rate>30.0</update_rate>

      <camera name="head">
        <horizontal_fov>1.3962634</horizontal_fov> <!-- ~80 degrees in radians being defined. -->

        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>

        <!-- This is used for clipping planes which are used for rendering purposes. -->
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>

        <!-- This is used for adding gaussian noise, to make the perception more realistic. -->
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>

      <!-- This is where the ROS Gazebo camera plugin is being defined. It publishes image and camera information topics into the ROS. 
           The cameraName becomes the namespace for topics, combined with the imageTopicName/cameraInfoTopicName. -->
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <alwaysOn>true</alwaysOn>
        <updateRate>0.0</updateRate> <!-- 0.0 means "as fast as possible". -->
        <cameraName>${prefix}/camera</cameraName>
        <imageTopicName>image_raw</imageTopicName>
        <cameraInfoTopicName>camera_info</cameraInfoTopicName>
        <frameName>${prefix}/camera_link</frameName>

        <!-- The remaining parameters are mostly relevant for stereo/distortion model. -->
        <hackBaseline>0.07</hackBaseline>
        <distortionK1>0.0</distortionK1>
        <distortionK2>0.0</distortionK2>
        <distortionK3>0.0</distortionK3>
        <distortionT1>0.0</distortionT1>
        <distortionT2>0.0</distortionT2>
      </plugin>
    </sensor>
  </gazebo>

  <!-- This is where the bumper contact sensor is being defined. It declares a Gazebo contact sensor and then maps it to a ROS topic. -->
  <gazebo reference="${prefix}/bumper_link">
    <material>Gazebo/Red</material>
    <sensor name="main_bumper" type="contact">
      <selfCollide>true</selfCollide>
      <alwaysOn>true</alwaysOn>
      <updateRate>15.0</updateRate>
      <contact>
        <collision>base_link_fixed_joint_lump__bumper_collision_collision_1</collision>
      </contact>

      <plugin name="gazebo_ros_bumper_controller" filename="libgazebo_ros_bumper.so">
        <robotNamespace>${prefix}</robotNamespace>
        <bumperTopicName>bumper_states</bumperTopicName>
        <frameName>${prefix}/bumper_link</frameName>
      </plugin>
    </sensor>
  </gazebo>

  <!-- This is where the Lidar/laser scanner is being defined. The Gazebo ray sensor will produce the LaserScan in the ROS via the libgazebo_ros_laser.so.
       This gives a value of 360 samples, which is a full 360 degress of the -pi and +pi with a range of 0.12 to the 12 metres. -->
  <gazebo reference="${prefix}/base_scan">
    <material>Gazebo/Black</material>
    <sensor type="ray" name="laser">
      <visualize>false</visualize>
      <update_rate>10</update_rate>

      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <min_angle>-3.14</min_angle>
            <max_angle>3.14</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>12.0</max>
        </range>
      </ray>

      <plugin name="gazebo_ros_laser" filename="libgazebo_ros_laser.so">
        <robotNamespace>${prefix}</robotNamespace>
        <topicName>scan</topicName>
        <frameName>${prefix}/base_scan</frameName>
      </plugin>
    </sensor>
  </gazebo>

  <!-- This is where the differential drive plugin is being defined. It reads the cmd_vel and then applies the wheel joint velocities. It publishes the 
       odom and TF of the nav_msgs/odometry. -->
  <gazebo>
    <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <robotNamespace>${prefix}</robotNamespace>
      <leftJoint>${prefix}/wheel_left_joint</leftJoint>
      <rightJoint>${prefix}/wheel_right_joint</rightJoint>

      <wheelSeparation>0.26</wheelSeparation>
      <wheelDiameter>0.2</wheelDiameter>

      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>

      <!-- This is defining the frames for odom and base reference. -->
      <odometryFrame>${prefix}/odom</odometryFrame>
      <robotBaseFrame>${prefix}/base_footprint</robotBaseFrame>

      <!-- This is where the TF publication control is being defined. -->
      <publishTf>true</publishTf>
      <publishOdomTF>true</publishOdomTF>
      <publishWheelTF>false</publishWheelTF>

      <updateRate>30.0</updateRate>
      <odometrySource>world</odometrySource>
    </plugin>
  </gazebo>

  <!-- This is where the Gazebo material and frictin tweaks per link are defined. These will only affect the Gazebo simulation and not the RViz. 
       The wheels are high friction so that they grip and the mu1/mu2=2. The caster mu1/mu2=0, this is so they slide easier and do not fight turning. -->
  <gazebo reference="${prefix}/base_link"><material>Gazebo/Purple</material></gazebo>
  <gazebo reference="${prefix}/left_wheel">
    <material>Gazebo/Black</material>
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
  </gazebo>
  <gazebo reference="${prefix}/right_wheel">
    <material>Gazebo/Black</material>
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
  </gazebo>
  <gazebo reference="${prefix}/caster_link">
    <material>Gazebo/Black</material>
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

</robot>
