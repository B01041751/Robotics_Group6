<?xml version="1.0" ?>
<robot name="com760Bot" xmlns:xacro="https://www.ros.org/wiki/xacro" >
    
 <!-- Xacro support added (body intentionally untouched) -->
  <xacro:property name="robot_name" value="Group6Bot_1"/>

    <!-- Create a robot chassis as Base Link -->
    <link name="${robot_name}/base_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
              <box size="0.5 0.3 0.07"/>
            </geometry>
            <material name="blue">
                  <color rgba="0.0 0.5 1.0 1.0"/>
            </material>
       </visual>
      <!-- Base pose, collision and inertial -->
      <pose>0 0 0.1 0 0 0</pose>
      <collision>
        <geometry>
          <box size="0.5 0.3 0.07"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="5"/>
        <origin rpy="0 0 0" xyz="0 0 0.1"/>
        <inertia ixx="0.03954" ixy="0" ixz="0" iyy="0.10621" iyz="0" izz="0.10621"/>
      </inertial>
     
      <!-- caster -->
        <visual name="caster">
        <origin rpy=" 0 0 0" xyz="0.2 0 -0.05"/>
        <geometry>
          <sphere radius="0.05"/>
        </geometry>
        <material name="black">
          <color rgba="0.05 0.05 0.05 1.0"/>
        </material>
      </visual> 
      <!-- Caster collision and inertial -->
        <collision>
        <origin xyz="0.35 0 -0.05" rpy="0 0 0" />
        <geometry>
          <sphere radius="0.05" />
        </geometry>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0005"/>
      </inertial> 
    </link>
    
    <!-- Caster -->  
<link name="${robot_name}/caster_link">
  <visual>
    <geometry>
      <sphere radius="0.05"/>
    </geometry>
  </visual>
</link>

<joint name="caster_joint" type="fixed">
  <parent link="${robot_name}/base_link"/>
  <child link="${robot_name}/caster_link"/>
  <origin xyz="0.2 0 -0.05"/>
</joint>

  
  <!-- Create wheel right -->  
     <link name="${robot_name}/right_wheel">      
        <visual>
          <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
          <geometry>
            <cylinder length="0.04" radius="0.1"/>
          </geometry>      
        </visual>
        <!--right wheel collision and inertial-->  
        <collision>
          <origin rpy="0 1.5707 1.5707" xyz="0 0 0" />
          <geometry>
            <cylinder length="0.04" radius="0.1"/>
          </geometry>
        </collision>
        <inertial>
          <mass value="0.2"/>
          <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
          <inertia ixx="0.000527" ixy="0" ixz="0" iyy="0.000527" iyz="0" izz="0.001"/>
        </inertial>  
    </link>
    
    <!--   Joint for right wheel  -->
    <joint name="joint_right_wheel" type="continuous">
      <origin rpy="0 0 0" xyz="-0.05 0.15 0"/>
      <child link="${robot_name}/right_wheel"/>
      <parent link="${robot_name}/base_link"/>
      <axis rpy="0 0 0" xyz="0 1 0"/>
      <limit effort="10000" velocity="1000"/>
      <joint_properties damping="1.0" friction="1.0" />
    </joint>  
    
    <!-- Left Wheel link -->   
    <link name="${robot_name}/left_wheel">    
      <visual>
        <origin rpy="0 1.5706 1.5707" xyz="0 0 0"/>
        <geometry>
          <cylinder length="0.04" radius="0.1"/>
        </geometry>      
      </visual> 
      <!--left wheel collision and inertial-->
      <collision>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0" />
        <geometry>
          <cylinder length="0.04" radius="0.1"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.2"/>
        <origin rpy="0 1.5707 1.5707" xyz="0 0 0"/>
        <inertia ixx="0.000527" ixy="0" ixz="0" iyy="0.000527" iyz="0" izz="0.001"/>
      </inertial>      
      
    </link>
    
    <!--   Joint for left wheel  -->
    <joint name="joint_left_wheel" type="continuous">
      <origin rpy="0 0 0" xyz="-0.05 -0.15 0"/>
      <child link="${robot_name}/left_wheel"/>
      <parent link="${robot_name}/base_link"/>
      <axis rpy="0 0 0" xyz="0 1 0"/>
      <limit effort="10000" velocity="1000"/>
      <joint_properties damping="1.0" friction="1.0" />
    </joint>

    <!--specifying color in Gazebo-->
    <gazebo reference="${robot_name}/base_link">
        <material>Gazebo/Green</material>
    </gazebo>
    <gazebo reference="${robot_name}/left_wheel">
        <material>Gazebo/Red</material>
    </gazebo>
    <gazebo reference="${robot_name}/right_wheel">
        <material>Gazebo/Red</material>
    </gazebo>

    <!--adding a differential drive plugin-->
    <gazebo>
      <plugin filename="libgazebo_ros_diff_drive.so" name="differential_drive_controller">
        <alwaysOn>true</alwaysOn>
        <updateRate>20</updateRate>
        <leftJoint>joint_left_wheel</leftJoint>
        <rightJoint>joint_right_wheel</rightJoint>
        <wheelSeparation>0.4</wheelSeparation>
        <wheelDiameter>0.2</wheelDiameter>
        <torque>0.1</torque>
        <robotNamespace>${robot_name}</robotNamespace>
        <commandTopic>cmd_vel</commandTopic>
        <odometryTopic>odom</odometryTopic>
        <odometryFrame>${robot_name}/odom</odometryFrame>
        <robotBaseFrame>${robot_name}/base_link</robotBaseFrame>
        <!-- Set to true to publish transforms for the wheel links, defaults to false -->
        <publishWheelTF>false</publishWheelTF>
        <!-- Set to true to publish sensor_msgs/JointState on /joint_states for the wheel joints, defaults to false -->
        <publishWheelJointState>true</publishWheelJointState>
        <legacyMode>true</legacyMode> 
      </plugin>
    </gazebo>
  
     <!--   Adding a camera -->
  <joint name="camera_joint" type="fixed">
        <parent link="${robot_name}/base_link"/>
        <child link="${robot_name}/camera_link"/>
        <origin xyz="0.25 0 0" rpy="0 0 0"/>
    </joint>

    <link name="${robot_name}/camera_link">
        <visual>
            <geometry>
                <box size="0.010 0.03 0.03"/>
            </geometry>
            <material name="red"/>
        </visual>
    </link>

    <link name="${robot_name}/camera_link_optical"></link>

     <joint name="camera_optical_joint" type="fixed">
        <parent link="${robot_name}/camera_link"/>
        <child link="${robot_name}/camera_link_optical"/>
        <origin xyz="0 0 0" rpy="-1.57 0 -1.57"/>
    </joint>

    <gazebo reference="${robot_name}/camera_link">
        <material>Gazebo/Red</material>

        <sensor name="camera" type="camera">
            <pose> 0 0 0 0 0 0 </pose>
            <visualize>false</visualize>
            <update_rate>10</update_rate>
            <camera>
                <horizontal_fov>1.089</horizontal_fov>
                <image>
                    <format>R8G8B8</format>
                    <width>640</width>
                    <height>480</height>
                </image>
                <clip>
                    <near>0.05</near>
                    <far>8.0</far>
                </clip>
            </camera>
            <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
                <!--frame_name>camera_link_optical</frame_name-->
                <alwaysOn>true</alwaysOn>
                <updateRate>0.0</updateRate>
                <cameraName>${robot_name}/camera</cameraName>
                <imageTopicName>image_raw</imageTopicName>
                <cameraInfoTopicName>camera_info</cameraInfoTopicName>
                <frameName>${robot_name}/camera_link_optical</frameName>
            </plugin>
        </sensor>
    </gazebo>
    
    <!-- Adding LiDAR sensor -->
    <link name="${robot_name}/laser_link">
  <visual>
    <geometry>
      <cylinder length="0.05" radius="0.05"/>
    </geometry>
  </visual>
</link>

<joint name="laser_joint" type="fixed">
  <parent link="${robot_name}/base_link"/>
  <child link="${robot_name}/laser_link"/>
  <origin xyz="0.0 0 0.1" rpy="0 0 0"/>
</joint>

<gazebo reference="${robot_name}/laser_link">
  <sensor type="ray" name="laser">
    <update_rate>10</update_rate>
    <ray>
      <scan>
        <horizontal>
          <samples>720</samples>
          <min_angle>-1.57</min_angle>
          <max_angle>1.57</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>0.1</min>
        <max>10.0</max>
      </range>
    </ray>

    <plugin name="laser_controller" filename="libgazebo_ros_laser.so">
      <topicName>${robot_name}/scan</topicName>
      <frameName>${robot_name}/laser_link</frameName>
    </plugin>

  </sensor>
</gazebo>

  
</robot>

