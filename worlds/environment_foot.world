  <!-- Entry obstacle walls — one in front of each bot spawn -->
  
  <model name="entry_obstacle_bot0">
    <static>true</static>
    <pose>-5.0000 -3.7819 0.50 0 0 0</pose>
    <link name="link">
      <collision name="c"><geometry><box><size>0.20 3.00 1.00</size></box></geometry><surface><friction><ode><mu>100</mu><mu2>50</mu2></ode></friction></surface></collision>
